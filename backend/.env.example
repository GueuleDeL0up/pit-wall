# Copier ce fichier en `.env` (gitignore) et renseigner les valeurs réelles.

# Base de données partagée (AlwaysData)
PITWALL_DB_HOST=
PITWALL_DB_PORT=3306
PITWALL_DB_USER=pitwallg2
PITWALL_DB_PASSWORD=
PITWALL_DB_NAME=

# Port série STM32 (port virtuel du ST-Link, voir backend/README.md)
PITWALL_SERIAL_PORT=COM6
PITWALL_SERIAL_BAUDRATE=9600
